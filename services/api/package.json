{
  "name": "@opensupportai/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./answer-runtime": {
      "types": "./dist/answer-runtime.d.ts",
      "default": "./dist/answer-runtime.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:demo": "tsx watch src/demo.ts",
    "build": "tsc -p tsconfig.json && esbuild src/index.ts --bundle --platform=node --format=esm --sourcemap --outfile=dist/index.js --external:@prisma/client --external:@prisma/adapter-pg --external:fastify --external:@fastify/cors --external:dotenv/config && esbuild src/answer-runtime.ts --bundle --platform=node --format=esm --sourcemap --outfile=dist/answer-runtime.js --external:@prisma/client --external:@prisma/adapter-pg",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "prisma migrate deploy --config ../../prisma.config.ts",
    "db:seed": "prisma db seed --config ../../prisma.config.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@opensupportai/adapter-channels": "workspace:*",
    "@opensupportai/adapter-chatwoot": "workspace:*",
    "@opensupportai/evals": "workspace:*",
    "@opensupportai/llm": "workspace:*",
    "@opensupportai/protocol": "workspace:*",
    "@opensupportai/rag": "workspace:*",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "zod": "^4.4.3"
  }
}
