{
  "name": "@opensupportai/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "prisma migrate deploy --config ../../prisma.config.ts",
    "db:seed": "prisma db seed --config ../../prisma.config.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@opensupportai/adapter-channels": "workspace:*",
    "@opensupportai/adapter-chatwoot": "workspace:*",
    "@opensupportai/llm": "workspace:*",
    "@opensupportai/protocol": "workspace:*",
    "@prisma/client": "^7.8.0",
    "fastify": "^5.8.5",
    "zod": "^4.4.3"
  }
}
