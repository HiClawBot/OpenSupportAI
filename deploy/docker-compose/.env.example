NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
ADMIN_API_TOKEN=admin_demo_key
CLIENT_TOKEN_SECRET=replace_with_32_byte_client_token_secret
ENCRYPTION_KEY=replace_with_32_byte_key
OPENSUPPORTAI_STORAGE=prisma
CORS_ORIGIN=*
CONVERSATION_TOKEN_TTL_SECONDS=604800
STREAM_TOKEN_TTL_SECONDS=60
SSE_HEARTBEAT_MS=15000
ALLOW_PRIVATE_OUTBOUND=true

POSTGRES_USER=opensupportai
POSTGRES_PASSWORD=opensupportai
POSTGRES_DB=opensupportai
POSTGRES_PORT=5432
DATABASE_URL=postgresql://opensupportai:opensupportai@localhost:5432/opensupportai

REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=opensupportai
S3_FORCE_PATH_STYLE=true

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace_me
LLM_DEFAULT_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

CHATWOOT_BASE_URL=http://localhost:3008
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=1
CHATWOOT_API_ACCESS_TOKEN=replace_me
CHATWOOT_WEBHOOK_SECRET=replace_me
