{
  "name": "opensupportai",
  "version": "0.1.2",
  "private": true,
  "description": "Open-source, embeddable, LLM-native AI support runtime.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "smoke:chatwoot": "node scripts/chatwoot-smoke.mjs"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/node": "latest",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "eslint": "latest",
    "prettier": "latest",
    "prisma": "^7.8.0",
    "tsx": "latest",
    "turbo": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma"
    ]
  }
}
