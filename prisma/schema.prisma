generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projects  Project[]
  apiKeys   ApiKey[]
  auditLogs AuditLog[]

  @@map("organizations")
}

model Project {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  publicKey      String   @unique @map("public_key")
  defaultLocale  String   @default("zh-CN") @map("default_locale")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inboxes              Inbox[]
  contacts             Contact[]
  conversations        Conversation[]
  messages             Message[]
  knowledgeSources     KnowledgeSource[]
  knowledgeDocuments   KnowledgeDocument[]
  knowledgeChunks      KnowledgeChunk[]
  llmProviders         LlmProvider[]
  aiRuns               AiRun[]
  handoffSessions      HandoffSession[]
  integrationConfigs   IntegrationConfig[]
  webhookEvents        WebhookEvent[]
  apiKeys              ApiKey[]
  asyncJobs            AsyncJob[]
  auditLogs            AuditLog[]
  toolDefinitions      ToolDefinition[]
  toolCalls            ToolCall[]
  conversationInsights ConversationInsight[]

  @@index([organizationId])
  @@map("projects")
}

model Inbox {
  id              String   @id @default(cuid())
  projectId       String   @map("project_id")
  name            String
  handoffProvider String?  @map("handoff_provider")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([id, projectId])
  @@index([projectId])
  @@map("inboxes")
}

model Contact {
  id             String   @id @default(cuid())
  projectId      String   @map("project_id")
  externalUserId String?  @map("external_user_id")
  name           String?
  email          String?
  avatarUrl      String?  @map("avatar_url")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([id, projectId])
  @@unique([projectId, externalUserId])
  @@unique([projectId, email])
  @@index([projectId])
  @@map("contacts")
}

model Conversation {
  id              String    @id @default(cuid())
  projectId       String    @map("project_id")
  inboxId         String    @map("inbox_id")
  contactId       String    @map("contact_id")
  status          String    @default("open")
  assigneeType    String    @default("ai") @map("assignee_type")
  lastMessageAt   DateTime? @map("last_message_at")
  idempotencyKey  String?   @map("idempotency_key")
  idempotencyHash String?   @map("idempotency_hash")
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inbox           Inbox                @relation(fields: [inboxId], references: [id], onDelete: Restrict)
  contact         Contact              @relation(fields: [contactId], references: [id], onDelete: Restrict)
  messages        Message[]
  aiRuns          AiRun[]
  handoffSessions HandoffSession[]
  toolCalls       ToolCall[]
  insight         ConversationInsight?

  @@unique([id, projectId])
  @@unique([projectId, idempotencyKey])
  @@index([projectId])
  @@index([projectId, contactId])
  @@index([projectId, status])
  @@index([projectId, lastMessageAt])
  @@map("conversations")
}

model Message {
  id              String   @id @default(cuid())
  sequence        BigInt   @unique @default(autoincrement())
  conversationId  String   @map("conversation_id")
  projectId       String   @map("project_id")
  role            String
  visibility      String   @default("public")
  contentType     String   @default("text") @map("content_type")
  content         Json
  sourceRefs      Json?    @map("source_refs")
  idempotencyKey  String?  @map("idempotency_key")
  idempotencyHash String?  @map("idempotency_hash")
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  aiRuns       AiRun[]
  toolCalls    ToolCall[]

  @@unique([conversationId, idempotencyKey])
  @@index([projectId])
  @@index([conversationId, createdAt])
  @@index([projectId, createdAt])
  @@map("messages")
}

model KnowledgeSource {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  type      String
  name      String
  config    Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documents KnowledgeDocument[]

  @@index([projectId])
  @@map("knowledge_sources")
}

model KnowledgeDocument {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  sourceId    String?  @map("source_id")
  title       String
  sourceType  String   @map("source_type")
  sourceUri   String?  @map("source_uri")
  content     String   @default("")
  status      String   @default("pending")
  contentHash String?  @map("content_hash")
  metadata    Json     @default("{}")
  error       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source  KnowledgeSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  chunks  KnowledgeChunk[]

  @@index([projectId, status])
  @@index([projectId, contentHash])
  @@index([sourceId])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id         String                       @id @default(cuid())
  projectId  String                       @map("project_id")
  documentId String                       @map("document_id")
  chunkIndex Int                          @map("chunk_index")
  content    String
  embedding  Unsupported("vector(1536)")?
  tokenCount Int?                         @map("token_count")
  metadata   Json                         @default("{}")
  createdAt  DateTime                     @default(now()) @map("created_at")

  project  Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([documentId])
  @@index([projectId, documentId])
  @@map("knowledge_chunks")
}

model LlmProvider {
  id              String   @id @default(cuid())
  projectId       String   @map("project_id")
  provider        String   @default("openai_compatible")
  baseUrl         String   @map("base_url")
  model           String
  embeddingModel  String?  @map("embedding_model")
  apiKeyEncrypted String   @map("api_key_encrypted")
  status          String   @default("active")
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, status])
  @@map("llm_providers")
}

model AiRun {
  id                String   @id @default(cuid())
  projectId         String   @map("project_id")
  conversationId    String   @map("conversation_id")
  messageId         String?  @map("message_id")
  provider          String
  model             String
  promptVersion     String   @map("prompt_version")
  inputTokens       Int?     @map("input_tokens")
  outputTokens      Int?     @map("output_tokens")
  latencyMs         Int?     @map("latency_ms")
  retrievedChunkIds Json     @default("[]") @map("retrieved_chunk_ids")
  confidence        Float?
  status            String
  error             String?
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now()) @map("created_at")

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message?     @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([conversationId, createdAt])
  @@index([messageId])
  @@index([status])
  @@map("ai_runs")
}

model HandoffSession {
  id                     String   @id @default(cuid())
  projectId              String   @map("project_id")
  conversationId         String   @map("conversation_id")
  provider               String
  externalContactId      String?  @map("external_contact_id")
  externalConversationId String?  @map("external_conversation_id")
  status                 String   @default("requested")
  reason                 String?
  metadata               Json     @default("{}")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([projectId, provider, externalConversationId], map: "handoff_project_provider_external_conversation_key")
  @@index([projectId])
  @@index([conversationId])
  @@map("handoff_sessions")
}

model IntegrationConfig {
  id              String   @id @default(cuid())
  projectId       String   @map("project_id")
  provider        String
  status          String   @default("active")
  configEncrypted String   @map("config_encrypted")
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, provider])
  @@map("integration_configs")
}

model WebhookEvent {
  id                  String    @id @default(cuid())
  projectId           String    @map("project_id")
  provider            String
  externalEventId     String?   @map("external_event_id")
  payload             Json
  status              String    @default("received")
  error               String?
  createdAt           DateTime  @default(now()) @map("created_at")
  processedAt         DateTime? @map("processed_at")
  processingStartedAt DateTime? @map("processing_started_at")
  attempts            Int       @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, provider, externalEventId])
  @@index([projectId, provider])
  @@index([status, createdAt])
  @@map("webhook_events")
}

model ApiKey {
  id             String    @id @default(cuid())
  projectId      String?   @map("project_id")
  organizationId String?   @map("organization_id")
  name           String
  keyHash        String    @unique @map("key_hash")
  scopes         Json      @default("[]")
  lastUsedAt     DateTime? @map("last_used_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  revokedAt      DateTime? @map("revoked_at")

  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([organizationId])
  @@map("api_keys")
}

model AuditLog {
  id             String   @id @default(cuid())
  projectId      String?  @map("project_id")
  organizationId String?  @map("organization_id")
  actorType      String   @map("actor_type")
  actorId        String?  @map("actor_id")
  action         String
  targetType     String?  @map("target_type")
  targetId       String?  @map("target_id")
  metadata       Json     @default("{}")
  requestId      String?  @map("request_id")
  createdAt      DateTime @default(now()) @map("created_at")

  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([organizationId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model ToolDefinition {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  slug         String
  name         String
  description  String
  kind         String   @default("demo")
  status       String   @default("active")
  method       String?
  path         String?
  inputSchema  Json     @default("{}") @map("input_schema")
  outputSchema Json     @default("{}") @map("output_schema")
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  calls   ToolCall[]

  @@unique([projectId, slug])
  @@index([projectId, status])
  @@map("tool_definitions")
}

model ToolCall {
  id             String   @id @default(cuid())
  projectId      String   @map("project_id")
  conversationId String?  @map("conversation_id")
  messageId      String?  @map("message_id")
  toolId         String?  @map("tool_id")
  toolSlug       String   @map("tool_slug")
  status         String
  input          Json     @default("{}")
  output         Json?
  error          String?
  latencyMs      Int?     @map("latency_ms")
  createdAt      DateTime @default(now()) @map("created_at")

  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversation Conversation?   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message?        @relation(fields: [messageId], references: [id], onDelete: SetNull)
  tool         ToolDefinition? @relation(fields: [toolId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([conversationId, createdAt])
  @@index([toolSlug, createdAt])
  @@map("tool_calls")
}

model ConversationInsight {
  id               String   @id @default(cuid())
  projectId        String   @map("project_id")
  conversationId   String   @unique @map("conversation_id")
  summary          String
  suggestedReplies Json     @default("[]") @map("suggested_replies")
  tags             Json     @default("[]")
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([projectId, updatedAt])
  @@map("conversation_insights")
}

model AsyncJob {
  id             String    @id @default(cuid())
  projectId      String    @map("project_id")
  type           String
  status         String    @default("queued")
  payload        Json      @default("{}")
  result         Json?
  attempts       Int       @default(0)
  maxAttempts    Int       @default(3) @map("max_attempts")
  runAt          DateTime  @default(now()) @map("run_at")
  lockedBy       String?   @map("locked_by")
  lockedAt       DateTime? @map("locked_at")
  leaseExpiresAt DateTime? @map("lease_expires_at")
  error          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([status, runAt])
  @@index([type, status])
  @@map("async_jobs")
}
